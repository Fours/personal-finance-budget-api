
generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
    id            String  @id
    email         String  @unique
    name          String
    transactions  Transaction[]
    budgets       Budget[]
}

model Category {
    id            String  @id
    name          String  @unique
    hue           Int
    kind          String
    transactions  Transaction[]
    budgets       Budget[]
}

model Transaction {
    id          String    @id
    userId      String
    date        String
    merchant    String
    note        String
    amount      Int
    categoryId  String
    account     String
    kind        String
    user        User      @relation(fields: [userId], references: [id])
    category    Category  @relation(fields: [categoryId], references: [id])
}

model Budget {
    id          String    @id
    userId      String
    categoryId  String
    limit       Int
    rollover    Boolean
    user        User      @relation(fields: [userId], references: [id])
    category    Category  @relation(fields: [categoryId], references: [id])
}
